# Copy this file to .env.local and fill in your keys
# cp .env.local.example .env.local

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Anthropic Claude API – https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── JOB SEARCH APIs (at least one required) ───────────────────────────────────

# Option A · Adzuna  (free 250 req/month) – https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
ADZUNA_COUNTRY=us        # us | gb | au | ca | de | fr | in | ...

# Option B · JSearch via RapidAPI  (searches Indeed, LinkedIn, Glassdoor)
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key
