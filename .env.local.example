# Copy this file to .env.local and fill in your keys
# Windows:  copy .env.local.example .env.local
# Mac/Linux: cp .env.local.example .env.local

# ── LLM PROVIDER: pick Claude OR Ollama (not both) ────────────────────────────

# Option A · Claude API (paid, best quality)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Option B · Ollama (FREE, runs locally on your machine)
# 1. Download Ollama: https://ollama.com
# 2. Run in terminal: ollama pull llama3.2
# 3. Uncomment the two lines below:
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── JOB SEARCH APIs (at least one required) ───────────────────────────────────

# Option A · Adzuna (free 250 req/month)
# Sign up: https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
ADZUNA_COUNTRY=us

# Option B · JSearch via RapidAPI (searches Indeed, LinkedIn, Glassdoor)
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key
