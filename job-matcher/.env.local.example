# Copy this file to .env.local and fill in your API keys

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Anthropic Claude API key (resume analysis + job matching)
# Get one free at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── JOB SEARCH APIS (at least one required) ───────────────────────────────────

# Option A: Adzuna (free tier – 250 calls/month)
# Sign up at: https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
ADZUNA_COUNTRY=us   # us | gb | au | ca | de | fr | ...

# Option B: JSearch via RapidAPI (searches Indeed, LinkedIn, Glassdoor, ZipRecruiter)
# Sign up at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch (free tier available)
RAPIDAPI_KEY=your_rapidapi_key
